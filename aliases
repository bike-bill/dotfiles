if is_osx; then
    alias htop='sudo htop'

    ## ls ##
    alias ls='gls'
    alias rm='grm'
    
    alias chown='gchown --preserve-root'
    alias chmod='gchmod --preserve-root'
    alias chgrp='gchgrp --preserve-root'
fi

alias l.='ldot'
alias yarmorph='yay -Rns $(yay -Qtdq)'
alias t='todo.sh -d ~/.todo.cfg'
alias neofetch="neofetch --source ~/.config/neofetch/endeavouros_small"
alias hist="history | grep -E -v '^ *[0-9]+ *h ' | grep "

alias pn="pnpm"
alias gte="gnome-text-editor"

# Fix for GNOME Snapshot segfault on hybrid graphics
alias snapshot='GSK_RENDERER=cairo \snapshot'

